# 生产环境变量模板 —— 复制为 .env 并填写真实值后再部署。
# 生成密钥：
#   APP_KEY:    echo "base64:$(openssl rand -base64 32)"
#   JWT_SECRET: openssl rand -base64 48
# 切勿使用开发环境或示例中的任何密钥值！

# MySQL（容器内服务名为 mysql；用强密码）
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=__CHANGE_ME_strong_mysql_password__
DB_DATABASE=meedu

# Redis（容器内服务名为 redis；用强密码）
REDIS_HOST=redis
REDIS_PASSWORD=__CHANGE_ME_strong_redis_password__
REDIS_PORT=6379

# 应用密钥（必须自行生成，二者都必填）
APP_KEY=
JWT_SECRET=

# 队列：生产建议 redis（需另起 queue worker），简单场景可用 sync
QUEUE_DRIVER=sync

# MeiliSearch（用于站内搜索；不需要可留空 HOST）
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

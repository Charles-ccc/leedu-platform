# Leedu配置
# APP_KEY 必须自行生成!严禁直接使用示例值,否则等同硬编码默认密钥
# 生成方式:echo "base64:$(openssl rand -base64 32)"
# 或在容器内执行:docker compose exec leedu php artisan key:generate
APP_KEY=
# JWT_SECRET 必须自行生成!严禁直接使用示例值,否则等同硬编码默认密钥
# 生成方式:openssl rand -base64 48
# 或在容器内执行:docker compose exec leedu php artisan jwt:secret
JWT_SECRET=
QUEUE_DRIVER=sync

# MeiliSearch配置
